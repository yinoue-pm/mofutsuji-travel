{# ===========================================================================
   再利用マクロ群（編集型トラベルメディア版）
     icon / rating_badge / hero / route_map / toc
     section(章扉) / timeline_item / lodging_card / cost_summary
   - すべて self-contained（外部画像なし、インライン SVG）
   - 自動エスケープ前提（Jinja2 の autoescape=True）。安全な HTML は |safe を明示
   =========================================================================== #}

{# ---- インライン SVG アイコン（currentColor で着色） ---- #}
{% macro icon(name) -%}
{%- set paths = {
  'calendar': '<rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/>',
  'drive':    '<path d="M5 11l1.5-4.5A2 2 0 0 1 8.4 5h7.2a2 2 0 0 1 1.9 1.5L19 11"/><rect x="3" y="11" width="18" height="6" rx="2"/><circle cx="7.5" cy="17.5" r="1.4"/><circle cx="16.5" cy="17.5" r="1.4"/>',
  'yen':      '<path d="M7 4l5 7 5-7M12 11v9M8 14h8M8 17h8"/>',
  'onsen':    '<path d="M3 21h18M4 21v-7h16v7"/><path d="M8 10c0-1.5-1.2-2-1.2-3.3S8 4.5 8 3.5M12 10c0-1.5-1.2-2-1.2-3.3S12 4.5 12 3.5M16 10c0-1.5-1.2-2-1.2-3.3S16 4.5 16 3.5"/>',
  'meal':     '<path d="M5 2v8a2 2 0 0 0 2 2h0V2M7 2v20M16 2c-1.5 0-2.5 2-2.5 5s1 4 2.5 4v11"/>',
  'sight':    '<path d="M3 18l6-9 4 5 3-4 5 8z"/><circle cx="8" cy="6" r="2"/>',
  'ferry':    '<path d="M3 18c1.5 1 3 1 4.5 0s3-1 4.5 0 3 1 4.5 0 3-1 4.5 0"/><path d="M5 16l2-6h10l2 6M12 4v6M9 7h6"/>',
  'lodging':  '<path d="M3 18v-6a2 2 0 0 1 2-2h9a3 3 0 0 1 3 3v5M3 14h18M3 21v-3M21 21v-3"/>',
  'check':    '<path d="M20 6L9 17l-5-5"/>',
  'pin':      '<path d="M12 21s7-6.4 7-11a7 7 0 1 0-14 0c0 4.6 7 11 7 11z"/><circle cx="12" cy="10" r="2.5"/>',
  'star':     '<path d="M12 3l2.7 5.5 6 .9-4.3 4.2 1 6-5.4-2.8-5.4 2.8 1-6L3.3 9.4l6-.9z"/>',
  'print':    '<path d="M6 9V3h12v6M6 18H4a2 2 0 0 1-2-2v-4a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="7" rx="1"/>',
  'route':    '<circle cx="6" cy="6" r="2.5"/><circle cx="18" cy="18" r="2.5"/><path d="M8.5 6H15a3 3 0 0 1 0 6H9a3 3 0 0 0 0 6h6.5"/>'
} -%}
<svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"
     stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">{{ paths.get(name, paths['pin']) | safe }}</svg>
{%- endmacro %}

{# ---- 評価バッジ（食べログ等の点数） ---- #}
{% macro rating_badge(rating) -%}
<span class="rating" title="評価 {{ rating }}">{{ icon('star') }}<span class="num">{{ '%.2f'|format(rating) }}</span></span>
{%- endmacro %}

{# ---- hero（キッカー→大判明朝タイトル→リード文→統計→ルート） ---- #}
{% macro hero(doc) -%}
<header class="hero reveal" id="top">
  {% if doc.meta.hero_photo %}
  <div class="hero-photo"><img src="{{ doc.meta.hero_photo }}" alt="" decoding="async"></div>
  {% endif %}
  <p class="hero-kicker">ROAD TRIP ITINERARY</p>
  <h1 class="hero-title">{{ doc.meta.title }}</h1>
  {% if doc.meta.subtitle %}<p class="hero-sub">{{ doc.meta.subtitle }}</p>{% endif %}
  {% if doc.meta.lede %}<p class="hero-lede lede">{{ doc.meta.lede }}</p>{% endif %}
  {% if doc.meta.period %}<p class="hero-period">{{ icon('calendar') }}<span class="num">{{ doc.meta.period }}</span></p>{% endif %}

  {% if doc.hero_stats %}
  <div class="stats">
    {% for s in doc.hero_stats %}
    <div class="stat">
      <div class="stat-ico">{{ icon(s.icon or 'pin') }}</div>
      <div class="stat-val"><span class="num">{{ s.value }}</span>{% if s.unit %}<span class="stat-unit">{{ s.unit }}</span>{% endif %}</div>
      <div class="stat-label">{{ s.label }}</div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if doc.meta.route %}
  <div class="route">
    <div class="route-head">{{ icon('route') }}ルート概要</div>
    <p class="route-body">{{ doc.meta.route }}</p>
  </div>
  {% endif %}

  {# 青海波の意匠（写真ゼロでも映える和のあしらい・印刷でも線画として綺麗） #}
  <div class="hero-seigaiha" aria-hidden="true">
    <svg viewBox="0 0 1000 30" preserveAspectRatio="xMidYMax slice">
      <defs>
        <pattern id="seigaiha" width="80" height="40" patternUnits="userSpaceOnUse">
          <g fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="40" cy="40" r="36"/><circle cx="40" cy="40" r="24"/><circle cx="40" cy="40" r="12"/>
            <circle cx="0" cy="40" r="36"/><circle cx="0" cy="40" r="24"/><circle cx="0" cy="40" r="12"/>
            <circle cx="80" cy="40" r="36"/><circle cx="80" cy="40" r="24"/><circle cx="80" cy="40" r="12"/>
          </g>
        </pattern>
      </defs>
      <rect width="1000" height="30" fill="url(#seigaiha)"/>
    </svg>
  </div>
</header>
{%- endmacro %}

{# ---- SVG絵地図（手描き風ルート図）。各 section.pin を順に結ぶ ---- #}
{% macro route_map(doc) -%}
{%- set mp = doc.meta.map -%}
{%- set pinned = doc.sections | selectattr('pin') | list -%}
{%- if mp and pinned -%}
{%- set s = mp.start -%}
{%- set ns = namespace(d='M ' ~ s.x ~ ' ' ~ s.y) -%}
{%- for sec in pinned -%}{%- set ns.d = ns.d ~ ' L ' ~ sec.pin[0] ~ ' ' ~ sec.pin[1] -%}{%- endfor -%}
{%- set ns.d = ns.d ~ ' L ' ~ s.x ~ ' ' ~ s.y -%}
<section class="routemap reveal" id="routemap" aria-label="旅のルート図">
  <div class="rm-head">
    <p class="kicker">ROUTE MAP</p>
    <h2>旅のルート</h2>
  </div>
  <div class="rm-stage">
    <svg viewBox="0 0 {{ mp.w or 1000 }} {{ mp.h or 680 }}" role="img"
         aria-label="{{ doc.meta.route or '旅のルート図' }}" preserveAspectRatio="xMidYMid meet">
      {% for l in mp.labels or [] %}
      <text class="rm-region" x="{{ l.x }}" y="{{ l.y }}">{{ l.text }}</text>
      {% endfor %}
      <path class="rm-route" d="{{ ns.d }}"/>
      {# 発着地（福津） #}
      <g class="rm-node rm-start" transform="translate({{ s.x }},{{ s.y }})">
        <circle class="rm-pin-start" r="15"/>
        <path class="rm-home" d="M-6 2 L0 -6 L6 2 M-4 1 L-4 6 L4 6 L4 1"/>
        <text class="rm-label" y="34">{{ s.label }}</text>
      </g>
      {# 宿泊地（温泉＝朱の番号ノード） #}
      {% for sec in pinned %}
      <g class="rm-node" transform="translate({{ sec.pin[0] }},{{ sec.pin[1] }})">
        <circle class="rm-dot" r="17"/>
        <text class="rm-no num" y="6">{{ '%02d'|format(loop.index) }}</text>
        <text class="rm-label" y="40">{{ sec.map_label or sec.label }}{% if sec.night %} ♨{% endif %}</text>
      </g>
      {% endfor %}
    </svg>
  </div>
  <p class="rm-cap">総走行 <span class="num">{{ '{:,}'.format(doc.sections[-1].dist_km) }}</span> km ・ {{ doc.lodging_count }}泊{{ doc.sections|length }}日 ・ いで湯 <span class="num">{{ doc.lodging_count }}</span> 湯</p>
</section>
{%- endif -%}
{%- endmacro %}

{# ---- 目次（旅程ダイジェスト） ---- #}
{% macro toc(doc) -%}
<nav class="toc reveal" aria-label="目次">
  <p class="kicker">ITINERARY</p>
  <div class="toc-head">行程ダイジェスト</div>
  <ol class="toc-list">
    {% for s in doc.sections %}
    <li><a href="#{{ s.slug }}">
      <span class="toc-no num">{{ '%02d'|format(loop.index) }}</span>
      <span class="toc-main">
        <span class="toc-title"><span class="num">{{ s.date }}</span>（{{ s.weekday }}）</span>
        <span class="toc-meta">{% if s.night and s.night.card %}{{ s.night.card.name }}{% endif %}{% if s.dist_km is not none %} ・ 走行 <span class="num">{{ '{:,}'.format(s.dist_km) }}</span> km{% endif %}</span>
      </span>
    </a></li>
    {% endfor %}
  </ol>
</nav>
{%- endmacro %}

{# ---- セクション（1日＝章扉 ＋ タイムライン） ---- #}
{% macro section(sec, no) -%}
<section class="day" id="{{ sec.slug }}">
  <header class="day-hd reveal">
    <div class="day-no num">{{ '%02d'|format(no) }}</div>
    <div class="day-info">
      <p class="kicker">DAY {{ no }}</p>
      <h2 class="day-title"><span class="num">{{ sec.date }}</span>（{{ sec.weekday }}）</h2>
      <ul class="day-facts">
        {% if sec.dist_km is not none %}<li>{{ icon('drive') }}走行 <span class="num">{{ '{:,}'.format(sec.dist_km) }}</span> km</li>{% endif %}
        {% if sec.night and sec.night.card %}<li class="fact-onsen">{{ icon('onsen') }}{{ sec.night.card.name }}</li>{% endif %}
      </ul>
    </div>
  </header>
  {% if sec.items %}
  <ol class="timeline">
    {% for item in sec.items %}{{ timeline_item(item, sec.slug, loop.index0) }}{% endfor %}
  </ol>
  {% else %}
  <p class="empty">この日の予定は未登録です。</p>
  {% endif %}
</section>
{%- endmacro %}

{# ---- タイムライン上の1アイテム ---- #}
{% macro timeline_item(item, sec_slug, idx) -%}
{%- set iid = sec_slug ~ '-' ~ idx -%}
<li class="item reveal {{ 'is-highlight' if item.is_highlight else '' }}" data-type="{{ item.type }}" data-id="{{ iid }}">
  <button class="item-check" type="button" aria-pressed="false"
          aria-label="「{{ item.title }}」を訪問済みにする">{{ icon('check') }}</button>
  <div class="item-dot" data-type="{{ item.type }}">{{ icon(item.type) }}</div>
  <div class="item-body">
    {% if item.photo %}
    <figure class="item-photo">
      <img src="{{ item.photo }}" alt="{{ item.title }}" loading="lazy" decoding="async">
      {% if item.photo_credit %}<figcaption>{{ item.photo_credit }}</figcaption>{% endif %}
    </figure>
    {% endif %}
    <div class="item-head">
      {% if item.time %}<span class="item-time num">{{ item.time }}</span>{% endif %}
      <span class="item-title">{{ item.title }}</span>
      {% if item.rating %}{{ rating_badge(item.rating) }}{% endif %}
    </div>
    {% if item.desc %}<p class="item-desc">{{ item.desc }}</p>{% endif %}
    {% if item.cost is not none %}
      <span class="item-cost {{ 'is-minus' if item.cost < 0 else '' }}">
        {{ item.cost_label or '費用' }}　<span class="num">¥{{ '{:,}'.format(item.cost) }}</span>
      </span>
    {% endif %}
    {% if item.card %}{{ lodging_card(item.card) }}{% endif %}
  </div>
</li>
{%- endmacro %}

{# ---- 強調カード（宿泊：泉質・効能・価格・割引・連絡先） ---- #}
{% macro lodging_card(card) -%}
<div class="card">
  {% if card.photos %}
  <div class="card-gallery" data-count="{{ card.photos|length }}">
    {% for ph in card.photos %}<figure><img src="{{ ph }}" alt="{{ card.name }}" loading="lazy" decoding="async"></figure>{% endfor %}
  </div>
  {% elif card.photo %}
  <figure class="card-photo"><img src="{{ card.photo }}" alt="{{ card.name }}" loading="lazy" decoding="async"></figure>
  {% endif %}
  <div class="card-top">
    <span class="card-badge">{{ icon('onsen') }}{{ card.name }}</span>
    {% if card.spring %}<span class="card-spring">{{ card.spring }}</span>{% endif %}
  </div>
  <dl class="card-grid">
    {% if card.room %}<div><dt>部屋</dt><dd>{{ card.room }}</dd></div>{% endif %}
    {% if card.plan %}<div><dt>プラン</dt><dd>{{ card.plan }}</dd></div>{% endif %}
    {% if card.address %}<div><dt>所在</dt><dd>{{ card.address }}</dd></div>{% endif %}
    {% if card.tel %}<div><dt>電話</dt><dd><a href="tel:{{ card.tel|replace('-','') }}" class="num">{{ card.tel }}</a></dd></div>{% endif %}
  </dl>
  {% if card.benefits %}<p class="card-benefits"><span>効能</span>{{ card.benefits }}</p>{% endif %}
  {% if card.price is not none %}
  <div class="card-price">
    <span class="price-main num">¥{{ '{:,}'.format(card.price) }}</span>
    {% if card.discount %}<span class="price-disc">{{ card.discount_label or '割引' }} <span class="num">¥{{ '{:,}'.format(card.discount) }}</span></span>{% endif %}
    {% if card.net_price is not none and card.discount %}<span class="price-net">実質 <span class="num">¥{{ '{:,}'.format(card.net_price) }}</span></span>{% endif %}
  </div>
  {% endif %}
</div>
{%- endmacro %}

{# ---- 集計（横棒グラフ）。負数（割引）は別色 ---- #}
{% macro cost_summary(summary) -%}
{%- set maxabs = summary.breakdown | map(attribute='amount') | map('abs') | max -%}
{%- set costicons = {'ホテル代':'lodging','宿泊料':'lodging','食事代':'meal','交通費':'drive','高速料':'drive','フェリー代':'ferry','入場料':'sight','観覧料':'sight','割引':'yen'} -%}
<section class="summary reveal" id="summary" aria-label="費用集計">
  <div class="summary-head">
    <div><p class="kicker">BUDGET</p><h2>費用集計</h2></div>
    <div class="summary-total">合計 <strong class="num">¥{{ '{:,}'.format(summary.total) }}</strong></div>
  </div>
  {% if summary.note %}<p class="summary-note">{{ summary.note }}</p>{% endif %}
  <div class="bars">
    {% for row in summary.breakdown %}
    {%- set pct = (row.amount | abs) / maxabs * 100 if maxabs else 0 -%}
    <div class="bar-row {{ 'is-minus' if row.amount < 0 else '' }}">
      <div class="bar-label">{{ icon(costicons.get(row.label, 'yen')) }}{{ row.label }}</div>
      <div class="bar-track">
        <div class="bar-fill" style="--w: {{ '%.1f'|format(pct) }}%"></div>
      </div>
      <div class="bar-val num">¥{{ '{:,}'.format(row.amount) }}</div>
    </div>
    {% endfor %}
  </div>
</section>
{%- endmacro %}
