{% import 'macros.html.j2' as m %}<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
{# 端末のダークモード強制で色反転されないよう light 固定（要件） #}
<meta name="color-scheme" content="light">
<meta name="description" content="{{ doc.meta.title }}{% if doc.meta.subtitle %} — {{ doc.meta.subtitle }}{% endif %}">
<title>{{ doc.meta.title }}{% if doc.meta.subtitle %} | {{ doc.meta.subtitle }}{% endif %}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="{{ font_css_url }}">
<style>
/* ============================ デザイントークン ============================ */
:root {
  color-scheme: light;              /* forced dark でも反転させない */
{{ theme_css_vars }}
  --maxw: 860px;
  --radius: 14px;
}
* { box-sizing: border-box; }
html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; scroll-padding-top: 64px; }
@media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
body {
  margin: 0;
  font-family: var(--font-body);
  color: var(--ink);
  background: var(--bg-soft);
  line-height: 1.7;
  font-size: 15px;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
}
a { color: var(--accent-2); text-decoration: none; }
a:hover { text-decoration: underline; }
.ico { width: 1em; height: 1em; flex: none; vertical-align: -0.13em; }

/* ============================ 固定ナビ＋進捗バー ============================ */
.progress { position: fixed; top: 0; left: 0; height: 3px; width: 0;
  background: linear-gradient(90deg, var(--grad-from), var(--grad-to)); z-index: 60; transition: width .1s linear; }
.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50;
  display: flex; align-items: center; gap: 10px;
  padding: 8px max(14px, env(safe-area-inset-left)) 8px max(14px, env(safe-area-inset-right));
  background: rgba(255,255,255,.86); backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--line); }
.nav-title { font-family: var(--font-head); font-weight: 700; font-size: 14px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.nav-spacer { flex: 1; }
.btn { display: inline-flex; align-items: center; gap: 6px; cursor: pointer;
  font: inherit; font-size: 13px; font-weight: 700; color: #fff;
  background: var(--accent); border: 0; border-radius: 999px; padding: 8px 14px; }
.btn:hover { filter: brightness(1.06); }
.btn:focus-visible { outline: 3px solid var(--accent-2); outline-offset: 2px; }

/* ============================ レイアウト ============================ */
.wrap { max-width: var(--maxw); margin: 0 auto; padding: 64px 16px 80px; }

/* ---- hero ---- */
.hero { background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius);
  padding: 30px 22px; box-shadow: var(--shadow); }
.hero-kicker { margin: 0 0 6px; letter-spacing: .22em; font-size: 11px; font-weight: 700; color: var(--accent); }
.hero-title { margin: 0; font-family: var(--font-head); font-weight: 700; line-height: 1.2;
  font-size: clamp(26px, 7vw, 44px);
  background: linear-gradient(90deg, var(--grad-from), var(--grad-to));
  -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
.hero-sub { margin: 8px 0 0; font-weight: 700; color: var(--ink-soft); font-size: clamp(14px,3.6vw,18px); }
.hero-period { display: inline-flex; align-items: center; gap: 6px; margin: 16px 0 0;
  font-weight: 700; color: var(--ink); background: var(--bg-soft);
  border: 1px solid var(--line); border-radius: 999px; padding: 6px 14px; }

/* ---- サマリ統計 ---- */
.stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-top: 22px; }
@media (min-width: 560px) { .stats { grid-template-columns: repeat(4, 1fr); } }
.stat { text-align: center; padding: 14px 8px; border-radius: 12px;
  background: var(--accent-soft); border: 1px solid var(--line); }
.stat-ico { color: var(--accent); font-size: 22px; }
.stat-val { font-family: var(--font-head); font-weight: 700; font-size: 22px; line-height: 1.1; margin-top: 4px; }
.stat-unit { font-size: 12px; margin-left: 2px; color: var(--ink-soft); }
.stat-label { font-size: 12px; color: var(--ink-soft); margin-top: 2px; }

/* ---- ルート ---- */
.route { margin-top: 18px; padding: 14px 16px; border-radius: 12px;
  background: var(--accent-2-soft); border: 1px solid var(--line); }
.route-head { display: flex; align-items: center; gap: 6px; font-weight: 700; color: var(--accent-2); margin-bottom: 4px; }
.route-body { margin: 0; font-size: 13px; color: var(--ink); word-break: break-word; }

/* ---- 目次 ---- */
.toc { margin-top: 22px; background: var(--surface); border: 1px solid var(--line);
  border-radius: var(--radius); padding: 18px 20px; box-shadow: var(--shadow); }
.toc-head { font-family: var(--font-head); font-weight: 700; font-size: 16px; margin-bottom: 8px; }
.toc-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 2px; }
.toc-list a { display: grid; grid-template-columns: auto auto 1fr; gap: 8px; align-items: baseline;
  padding: 7px 6px; border-radius: 8px; color: var(--ink); }
.toc-list a:hover { background: var(--bg-soft); text-decoration: none; }
.toc-day { font-family: var(--font-head); font-weight: 700; color: var(--accent); }
.toc-meta { font-size: 12px; color: var(--ink-soft); white-space: nowrap; }
.toc-leg { font-size: 12px; color: var(--ink-soft); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* ---- セクション（日） ---- */
.day { margin-top: 30px; }
.day-head { position: sticky; top: 52px; z-index: 10;
  display: flex; align-items: center; gap: 12px; padding: 12px 14px;
  background: var(--surface); border: 1px solid var(--line); border-radius: 12px; box-shadow: var(--shadow); }
.day-badge { font-family: var(--font-head); font-weight: 700; color: #fff;
  background: linear-gradient(135deg, var(--grad-from), var(--grad-to));
  padding: 6px 12px; border-radius: 10px; white-space: nowrap; }
.day-meta { flex: 1; min-width: 0; }
.day-date { font-weight: 700; }
.day-date span { color: var(--ink-soft); font-weight: 400; }
.day-leg { font-size: 12.5px; color: var(--ink-soft); }
.day-dist { display: flex; align-items: center; gap: 4px; font-family: var(--font-head);
  font-weight: 700; color: var(--accent-2); white-space: nowrap; }
.day-dist span { font-size: 11px; color: var(--ink-soft); }

/* ---- タイムライン ---- */
.timeline { list-style: none; margin: 6px 0 0; padding: 0 0 0 6px; }
.item { position: relative; display: grid; grid-template-columns: 30px 1fr; gap: 12px;
  padding: 14px 0 14px 4px; border-left: 2px solid var(--line); margin-left: 13px; }
.item:last-child { border-left-color: transparent; }
.item-dot { position: relative; left: -16px; width: 30px; height: 30px; border-radius: 50%;
  display: grid; place-items: center; color: #fff; font-size: 15px;
  background: var(--accent-2); box-shadow: 0 0 0 4px var(--bg-soft); }
.item-dot[data-type="meal"]    { background: #e07a3f; }
.item-dot[data-type="sight"]   { background: #2e9e6b; }
.item-dot[data-type="drive"]   { background: #6b7280; }
.item-dot[data-type="ferry"]   { background: #1b6ca8; }
.item-dot[data-type="lodging"] { background: var(--accent); }
.item-body { min-width: 0; margin-left: -10px; }
.item-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 8px; }
.item-time { font-family: var(--font-head); font-weight: 700; font-size: 13px; color: var(--accent-2);
  background: var(--accent-2-soft); padding: 1px 8px; border-radius: 6px; white-space: nowrap; }
.item-title { font-weight: 700; font-size: 15.5px; }
.item-desc { margin: 4px 0 0; font-size: 13.5px; color: var(--ink-soft); }
.item-cost { display: inline-block; margin-top: 8px; font-size: 12.5px; font-weight: 700;
  color: var(--ink); background: var(--bg-soft); border: 1px solid var(--line);
  border-radius: 8px; padding: 3px 10px; }
.item-cost.is-minus { color: var(--ok); }
.rating { display: inline-flex; align-items: center; gap: 3px; font-family: var(--font-head);
  font-weight: 700; font-size: 12.5px; color: var(--gold); }
.rating .ico { color: var(--gold); }

/* 強調アイテム（カード付き / 高評価） */
.item.is-highlight > .item-body { background: var(--surface); border: 1px solid var(--line);
  border-left: 4px solid var(--accent); border-radius: 12px; padding: 12px 14px;
  box-shadow: var(--shadow); margin-left: -10px; }

/* 訪問済みチェック */
.item-check { position: absolute; left: -14px; top: 12px; z-index: 2;
  width: 26px; height: 26px; border-radius: 50%; border: 2px solid var(--line);
  background: var(--surface); color: transparent; cursor: pointer; display: grid; place-items: center;
  padding: 0; transition: background .15s, color .15s, border-color .15s; }
.item-check .ico { width: 15px; height: 15px; stroke-width: 3; }
.item-check:hover { border-color: var(--ok); }
.item-check:focus-visible { outline: 3px solid var(--accent-2); outline-offset: 2px; }
.item.is-done .item-check { background: var(--ok); border-color: var(--ok); color: #fff; }
.item.is-done .item-title { text-decoration: line-through; color: var(--ink-soft); }
.item.is-done .item-dot { opacity: .45; }

/* ---- 宿泊カード ---- */
.card { margin-top: 12px; background: var(--bg-soft); border: 1px solid var(--line); border-radius: 12px; padding: 14px; }
.card-top { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-bottom: 10px; }
.card-badge { display: inline-flex; align-items: center; gap: 5px; font-family: var(--font-head);
  font-weight: 700; color: #fff; background: var(--accent); border-radius: 8px; padding: 4px 10px; }
.card-spring { font-size: 12px; font-weight: 700; color: var(--accent-2);
  background: var(--accent-2-soft); border-radius: 8px; padding: 4px 10px; }
.card-grid { display: grid; grid-template-columns: 1fr; gap: 6px 16px; margin: 0; }
@media (min-width: 480px) { .card-grid { grid-template-columns: 1fr 1fr; } }
.card-grid div { display: grid; grid-template-columns: 48px 1fr; gap: 8px; }
.card-grid dt { font-size: 12px; font-weight: 700; color: var(--ink-soft); margin: 0; }
.card-grid dd { margin: 0; font-size: 13px; }
.card-benefits { margin: 10px 0 0; font-size: 12.5px; color: var(--ink-soft); }
.card-benefits span { display: inline-block; font-weight: 700; color: var(--accent);
  margin-right: 6px; background: var(--accent-soft); border-radius: 6px; padding: 1px 7px; }
.card-price { display: flex; flex-wrap: wrap; align-items: baseline; gap: 10px; margin-top: 12px;
  padding-top: 10px; border-top: 1px dashed var(--line); }
.price-main { font-family: var(--font-head); font-weight: 700; font-size: 20px; }
.price-disc { font-size: 12.5px; font-weight: 700; color: var(--ok); }
.price-net { margin-left: auto; font-family: var(--font-head); font-weight: 700; color: var(--accent); }

/* ---- 集計（横棒グラフ） ---- */
.summary { margin-top: 36px; background: var(--surface); border: 1px solid var(--line);
  border-radius: var(--radius); padding: 22px; box-shadow: var(--shadow); }
.summary-head { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 8px; }
.summary-head h2 { font-family: var(--font-head); margin: 0; font-size: 20px; }
.summary-total { font-size: 14px; color: var(--ink-soft); }
.summary-total strong { font-family: var(--font-head); font-size: 22px; color: var(--accent); }
.summary-note { margin: 4px 0 14px; font-size: 12px; color: var(--ink-soft); }
.bars { display: grid; gap: 10px; margin-top: 8px; }
.bar-row { display: grid; grid-template-columns: 78px 1fr auto; gap: 10px; align-items: center; }
.bar-label { font-size: 13px; font-weight: 700; }
.bar-track { background: var(--bg-soft); border-radius: 999px; height: 16px; overflow: hidden; }
.bar-fill { height: 100%; width: 0; border-radius: 999px;
  background: linear-gradient(90deg, var(--grad-from), var(--grad-to)); transition: width .9s cubic-bezier(.2,.7,.2,1); }
.bar-row.is-minus .bar-fill { background: linear-gradient(90deg, #2e9e6b, #7bd0a0); }
.bar-val { font-family: var(--font-head); font-weight: 700; font-size: 13px; white-space: nowrap; }
.is-visible .bar-fill { width: var(--w); }

/* 空セクション */
.empty { color: var(--ink-soft); font-size: 13px; padding: 12px; background: var(--bg-soft); border-radius: 10px; }

/* フッター */
.foot { margin-top: 40px; text-align: center; font-size: 12px; color: var(--ink-soft); }

/* ---- 出現演出（IntersectionObserver で .is-visible 付与） ---- */
.reveal { opacity: 0; transform: translateY(14px); transition: opacity .6s ease, transform .6s ease; }
.reveal.is-visible { opacity: 1; transform: none; }
@media (prefers-reduced-motion: reduce) { .reveal { opacity: 1 !important; transform: none !important; transition: none; } }

/* ===================================================================== */
/* 印刷 / PDF 忠実化（最重要）                                            */
/* ===================================================================== */
@media print {
  /* 背景グラフィック OFF でも色を出す */
  *, *::before, *::after {
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
  }
  @page { size: A4; margin: 14mm 12mm; }
  html { scroll-behavior: auto; }
  body { background: #fff; font-size: 11pt; }
  .wrap { max-width: none; padding: 0; }
  .no-print { display: none !important; }            /* 操作系（ナビ/ボタン/進捗） */
  /* 出現演出・バー幅を確定描画 */
  .reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
  .bar-fill { width: var(--w) !important; transition: none !important; }
  /* 分断防止 */
  .item, .card, .stat, .toc, .summary, .day-head, .route { break-inside: avoid; page-break-inside: avoid; }
  .day { break-inside: auto; }
  h1, h2, .day-head, .hero-title { break-after: avoid; }
  .day-head { position: static; box-shadow: none; }
  .hero, .toc, .summary { box-shadow: none; }
  .item.is-highlight > .item-body, .hero, .toc, .summary { box-shadow: none; }
  /* グラデーション文字は単色フォールバック（確実に視認） */
  .hero-title { -webkit-text-fill-color: var(--accent) !important; color: var(--accent) !important;
    background: none !important; }
  /* 1日目の見出しが宙に浮かないよう調整 */
  .toc { page-break-after: always; }
  a { color: var(--ink); }
}
</style>
</head>
<body>
<div class="progress no-print" id="progress" role="presentation"></div>
<nav class="nav no-print">
  <span class="nav-title">{{ doc.meta.title }}</span>
  <span class="nav-spacer"></span>
  <button class="btn" id="printBtn" type="button">{{ m.icon('print') }}PDF・印刷</button>
</nav>

<main class="wrap">
  {{ m.hero(doc) }}
  {{ m.toc(doc) }}

  {% for sec in doc.sections %}{{ m.section(sec) }}{% endfor %}

  {% if doc.summary %}{{ m.cost_summary(doc.summary) }}{% endif %}

  <footer class="foot">
    <p>{{ doc.meta.title }}{% if doc.meta.created %} ／ 作成 {{ doc.meta.created }}{% endif %}</p>
    <p>立寄り {{ doc.item_count }} 件・宿泊 {{ doc.lodging_count }} 泊</p>
  </footer>
</main>

<script>
(function () {
  "use strict";
  var reduceMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ---- localStorage ガード（無効環境でもメモリ動作） ---- */
  var STORE_KEY = "itinerary-done:{{ store_key }}";
  var mem = {};
  var ls = (function () {
    try {
      var t = "__t__"; window.localStorage.setItem(t, t); window.localStorage.removeItem(t);
      return window.localStorage;
    } catch (e) { return null; }
  })();
  function loadDone() {
    if (!ls) return mem;
    try { return JSON.parse(ls.getItem(STORE_KEY) || "{}") || {}; }
    catch (e) { return {}; }
  }
  function saveDone(state) {
    if (!ls) { mem = state; return; }
    try { ls.setItem(STORE_KEY, JSON.stringify(state)); }
    catch (e) { mem = state; }
  }

  /* ---- 訪問済みチェック（タップで切替＋保存） ---- */
  var done = loadDone();
  var items = document.querySelectorAll(".item[data-id]");
  items.forEach(function (el) {
    var id = el.getAttribute("data-id");
    var btn = el.querySelector(".item-check");
    if (done[id]) { el.classList.add("is-done"); if (btn) btn.setAttribute("aria-pressed", "true"); }
    if (btn) btn.addEventListener("click", function () {
      var now = !el.classList.contains("is-done");
      el.classList.toggle("is-done", now);
      btn.setAttribute("aria-pressed", now ? "true" : "false");
      done[id] = now;
      if (!now) { delete done[id]; }
      saveDone(done);
    });
  });

  /* ---- 進捗バー ---- */
  var progress = document.getElementById("progress");
  function onScroll() {
    var h = document.documentElement;
    var max = (h.scrollHeight - h.clientHeight);
    var p = max > 0 ? (h.scrollTop || document.body.scrollTop) / max : 0;
    if (progress) progress.style.width = (p * 100).toFixed(1) + "%";
  }
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  /* ---- 出現演出（IntersectionObserver / 非対応・低モーションは即表示） ---- */
  var reveals = document.querySelectorAll(".reveal");
  if (reduceMotion || !("IntersectionObserver" in window)) {
    reveals.forEach(function (el) { el.classList.add("is-visible"); });
  } else {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) { en.target.classList.add("is-visible"); io.unobserve(en.target); }
      });
    }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
    reveals.forEach(function (el) { io.observe(el); });
  }

  /* ---- 印刷ボタン ---- */
  var printBtn = document.getElementById("printBtn");
  if (printBtn) printBtn.addEventListener("click", function () { window.print(); });
})();
</script>
</body>
</html>
