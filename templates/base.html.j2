{% import 'macros.html.j2' as m %}<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
{# 端末のダークモード強制で色反転されないよう light 固定（要件） #}
<meta name="color-scheme" content="light">
<meta name="description" content="{{ doc.meta.title }}{% if doc.meta.subtitle %} — {{ doc.meta.subtitle }}{% endif %}">
<title>{{ doc.meta.title }}{% if doc.meta.subtitle %} | {{ doc.meta.subtitle }}{% endif %}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="{{ font_css_url }}">
<style>
/* ============================ デザイントークン ============================ */
:root {
  color-scheme: light;              /* forced dark でも反転させない */
{{ theme_css_vars }}
  --maxw: 880px;
  --radius: 14px;
}
* { box-sizing: border-box; }
html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; scroll-padding-top: 64px; }
@media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } }
body {
  margin: 0;
  font-family: var(--font-body);
  color: var(--ink);
  background: var(--bg);            /* 生成りの紙 */
  line-height: 1.85;
  font-size: 15px;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
}
a { color: var(--accent); text-decoration: none; }
a:hover { text-decoration: underline; }
.ico { width: 1em; height: 1em; flex: none; vertical-align: -0.13em; }

/* 編集タイポグラフィの共通クラス */
.num { font-family: var(--font-num); font-variant-numeric: tabular-nums; letter-spacing: .01em; }
.kicker { margin: 0 0 6px; font: 700 11.5px/1 var(--font-body); letter-spacing: .24em; color: var(--accent-2); }
.lede { font-size: clamp(14.5px, 2.6vw, 17px); line-height: 1.95; color: var(--ink-soft); }

/* ============================ 固定ナビ＋進捗バー ============================ */
.progress { position: fixed; top: 0; left: 0; height: 3px; width: 0;
  background: linear-gradient(90deg, var(--accent), var(--gold)); z-index: 60; transition: width .1s linear; }
.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50;
  display: flex; align-items: center; gap: 10px;
  padding: 8px max(14px, env(safe-area-inset-left)) 8px max(14px, env(safe-area-inset-right));
  background: rgba(250,247,242,.9); backdrop-filter: blur(8px);
  border-bottom: 1px solid var(--line); }
.nav-title { font-family: var(--font-head); font-weight: 700; font-size: 15px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.nav-spacer { flex: 1; }
.btn { display: inline-flex; align-items: center; gap: 6px; cursor: pointer;
  font: inherit; font-size: 13px; font-weight: 700; color: #fff;
  background: var(--accent-2); border: 0; border-radius: 999px; padding: 8px 14px; }
.btn:hover { filter: brightness(1.06); }
.btn:focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; }

/* ============================ レイアウト ============================ */
.wrap { max-width: var(--maxw); margin: 0 auto; padding: 64px 18px 90px; }

/* ---- hero（誌面の表紙）---- */
.hero { position: relative; overflow: hidden; padding: 26px 4px 30px; border-bottom: 2px solid var(--gold); }
/* ヒーロー写真（任意）。無ければ出さない。控えめなデュオトーンで誌面に馴染ませる */
.hero-photo { aspect-ratio: 16 / 7; margin: 0 0 20px; border-radius: 12px; overflow: hidden;
  border: 1px solid var(--line); background: var(--accent); }
.hero-photo img { width: 100%; height: 100%; object-fit: cover;
  filter: grayscale(.35) sepia(.12) contrast(1.04); }
/* 青海波（せいがいは）の意匠：写真ゼロでも誌面感を出す和のあしらい（線画＝印刷でも綺麗） */
.hero-seigaiha { color: var(--accent); opacity: .24; margin: 24px -4px -12px; line-height: 0; }
.hero-seigaiha svg { display: block; width: 100%; height: 30px; }
.hero-kicker { margin: 0 0 10px; letter-spacing: .26em; font-size: 11.5px; font-weight: 700; color: var(--accent-2); }
.hero-title { margin: 0; font-family: var(--font-head); font-weight: 800; line-height: 1.18;
  font-size: clamp(34px, 9vw, 60px); letter-spacing: .02em;
  background: linear-gradient(100deg, var(--grad-from), var(--grad-to));
  -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
.hero-sub { margin: 10px 0 0; font-family: var(--font-head); font-weight: 600; color: var(--ink); font-size: clamp(15px,3.6vw,19px); }
.hero-lede { margin: 14px 0 0; max-width: 34em; }
.hero-period { display: inline-flex; align-items: center; gap: 6px; margin: 18px 0 0;
  font-weight: 700; color: var(--accent); background: var(--accent-soft);
  border: 1px solid var(--line); border-radius: 999px; padding: 6px 16px; font-size: 14px; }

/* ---- サマリ統計 ---- */
.stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-top: 26px; }
@media (min-width: 560px) { .stats { grid-template-columns: repeat(4, 1fr); } }
.stat { text-align: center; padding: 16px 8px; border-radius: 12px;
  background: var(--surface); border: 1px solid var(--line); box-shadow: var(--shadow); }
.stat-ico { color: var(--accent-2); font-size: 22px; }
.stat-val { font-family: var(--font-head); font-weight: 700; font-size: 26px; line-height: 1.1; margin-top: 4px; color: var(--accent); }
.stat-unit { font-size: 12px; margin-left: 2px; color: var(--ink-soft); font-family: var(--font-body); }
.stat-label { font-size: 12px; color: var(--ink-soft); margin-top: 4px; letter-spacing: .04em; }

/* ---- ルート（テキスト概要） ---- */
.route { margin-top: 22px; padding: 16px 18px; border-radius: 12px;
  background: var(--accent-soft); border: 1px solid var(--line); }
.route-head { display: flex; align-items: center; gap: 6px; font-family: var(--font-head); font-weight: 700; color: var(--accent); margin-bottom: 6px; }
.route-body { margin: 0; font-size: 13px; color: var(--ink); word-break: break-word; line-height: 1.9; }

/* ---- SVG絵地図（手描き風ルート図） ---- */
.routemap { margin-top: 30px; background: var(--surface); border: 1px solid var(--line);
  border-radius: var(--radius); padding: 22px; box-shadow: var(--shadow); }
.rm-head { margin-bottom: 8px; }
.rm-head h2 { font-family: var(--font-head); margin: 0; font-size: 22px; color: var(--accent); }
.rm-stage { width: 100%; }
.rm-stage svg { width: 100%; height: auto; display: block; }
.rm-route { fill: none; stroke: var(--gold); stroke-width: 3; stroke-dasharray: 2 11;
  stroke-linecap: round; stroke-linejoin: round; opacity: .9; }
.rm-region { fill: var(--ink-soft); opacity: .42; font-family: var(--font-head); font-size: 26px;
  letter-spacing: .3em; text-anchor: middle; }
.rm-dot { fill: var(--accent-2); }
.rm-pin-start { fill: var(--accent); }
.rm-home { fill: none; stroke: #fff; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
.rm-no { fill: #fff; font-weight: 700; font-size: 18px; text-anchor: middle; }
.rm-label { fill: var(--ink); font-family: var(--font-head); font-weight: 600; font-size: 20px; text-anchor: middle; }
.rm-cap { margin: 10px 0 0; text-align: center; font-size: 13px; color: var(--ink-soft); }
.rm-cap .num { color: var(--accent-2); font-weight: 700; }

/* ---- 目次（旅程ダイジェスト） ---- */
.toc { margin-top: 26px; background: var(--surface); border: 1px solid var(--line);
  border-radius: var(--radius); padding: 22px 24px; box-shadow: var(--shadow); }
.toc-head { font-family: var(--font-head); font-weight: 700; font-size: 20px; margin-bottom: 12px; color: var(--accent); }
.toc-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 2px; }
.toc-list a { display: grid; grid-template-columns: auto 1fr; gap: 14px; align-items: baseline;
  padding: 10px 8px; border-radius: 8px; color: var(--ink); border-bottom: 1px solid var(--line); }
.toc-list li:last-child a { border-bottom: 0; }
.toc-list a:hover { background: var(--bg-soft); text-decoration: none; }
.toc-no { font-size: 20px; font-weight: 700; color: var(--gold); }
.toc-title { display: block; font-family: var(--font-head); font-weight: 600; font-size: 15.5px; }
.toc-meta { display: block; font-size: 12px; color: var(--ink-soft); margin-top: 2px; }

/* ---- セクション（日＝章扉） ---- */
.day { margin-top: 40px; }
.day-hd { display: grid; grid-template-columns: auto 1fr; gap: 18px; align-items: start;
  padding: 22px 0 16px; border-top: 2px solid var(--accent); }
.day-no { font-family: var(--font-num); font-weight: 700; font-size: clamp(46px, 13vw, 84px);
  line-height: .8; color: var(--gold); }
.day-info { min-width: 0; }
.day-title { font-family: var(--font-head); font-weight: 700; color: var(--accent);
  font-size: clamp(20px, 5.2vw, 30px); line-height: 1.35; margin: 2px 0 0; }
.day-lede { margin: 8px 0 0; max-width: 36em; }
.day-facts { display: flex; flex-wrap: wrap; gap: 8px 16px; list-style: none; padding: 0; margin: 12px 0 0; }
.day-facts li { display: inline-flex; align-items: center; gap: 5px; font-size: 13px; font-weight: 700; color: var(--ink); }
.day-facts .ico { color: var(--accent-2); }
.day-facts .fact-onsen { color: var(--accent-2); }
.day-leg { margin: 8px 0 0; font-size: 12.5px; color: var(--ink-soft); }

/* ---- タイムライン ---- */
.timeline { list-style: none; margin: 10px 0 0; padding: 0 0 0 6px; }
.item { position: relative; display: grid; grid-template-columns: 30px 1fr; gap: 12px;
  padding: 14px 0 14px 4px; border-left: 2px solid var(--line); margin-left: 13px; }
.item:last-child { border-left-color: transparent; }
.item-dot { position: relative; left: -16px; width: 30px; height: 30px; border-radius: 50%;
  display: grid; place-items: center; color: #fff; font-size: 15px;
  background: var(--accent); box-shadow: 0 0 0 4px var(--bg); }
.item-dot[data-type="meal"]    { background: #c2723a; }
.item-dot[data-type="sight"]   { background: #3f7d5a; }
.item-dot[data-type="drive"]   { background: #8a8175; }
.item-dot[data-type="ferry"]   { background: var(--accent); }
.item-dot[data-type="lodging"] { background: var(--accent-2); }
.item-body { min-width: 0; margin-left: -10px; }
.item-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 8px; }
.item-time { font-weight: 700; font-size: 13.5px; color: var(--accent); letter-spacing: .02em;
  background: var(--accent-soft); padding: 1px 9px; border-radius: 6px; white-space: nowrap; }
.item-title { font-family: var(--font-head); font-weight: 700; font-size: 16px; }
.item-desc { margin: 5px 0 0; font-size: 13.5px; color: var(--ink-soft); }
.item-cost { display: inline-block; margin-top: 9px; font-size: 12.5px; font-weight: 700;
  color: var(--ink); background: var(--bg-soft); border: 1px solid var(--line);
  border-radius: 8px; padding: 3px 10px; }
.item-cost.is-minus { color: var(--ok); }
.rating { display: inline-flex; align-items: center; gap: 3px; font-weight: 700; font-size: 12.5px; color: var(--gold); }
.rating .ico { color: var(--gold); }

/* 写真スロット（任意・無ければ出さない）。デュオトーンで全写真のトーンを統一 */
.item-photo, .card-photo { margin: 0 0 10px; border-radius: 10px; overflow: hidden;
  border: 1px solid var(--line); background: var(--accent); }
.item-photo { aspect-ratio: 16 / 9; }
.card-photo { aspect-ratio: 3 / 2; margin-bottom: 12px; }
.item-photo img, .card-photo img { width: 100%; height: 100%; object-fit: cover;
  filter: grayscale(1) contrast(1.05); mix-blend-mode: luminosity; opacity: .92; }
.item-photo figcaption, .card-photo figcaption { font-size: 11px; color: var(--ink-soft); padding: 4px 2px 0; }

/* 強調アイテム（カード付き / 高評価） */
.item.is-highlight > .item-body { background: var(--surface); border: 1px solid var(--line);
  border-left: 4px solid var(--accent-2); border-radius: 12px; padding: 14px 16px;
  box-shadow: var(--shadow); margin-left: -10px; }

/* 訪問済みチェック */
.item-check { position: absolute; left: -14px; top: 12px; z-index: 2;
  width: 26px; height: 26px; border-radius: 50%; border: 2px solid var(--line);
  background: var(--surface); color: transparent; cursor: pointer; display: grid; place-items: center;
  padding: 0; transition: background .15s, color .15s, border-color .15s; }
.item-check .ico { width: 15px; height: 15px; stroke-width: 3; }
.item-check:hover { border-color: var(--ok); }
.item-check:focus-visible { outline: 3px solid var(--accent); outline-offset: 2px; }
.item.is-done .item-check { background: var(--ok); border-color: var(--ok); color: #fff; }
.item.is-done .item-title { text-decoration: line-through; color: var(--ink-soft); }
.item.is-done .item-dot { opacity: .45; }

/* ---- 宿泊カード ---- */
.card { margin-top: 12px; background: var(--bg-soft); border: 1px solid var(--line); border-radius: 12px; padding: 16px; }
.card-top { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-bottom: 12px; }
.card-badge { display: inline-flex; align-items: center; gap: 5px; font-family: var(--font-head);
  font-weight: 700; color: #fff; background: var(--accent-2); border-radius: 8px; padding: 4px 12px; }
.card-spring { font-size: 12px; font-weight: 700; color: var(--accent);
  background: var(--accent-soft); border: 1px solid var(--line); border-radius: 8px; padding: 4px 10px; }
.card-grid { display: grid; grid-template-columns: 1fr; gap: 7px 18px; margin: 0; }
@media (min-width: 480px) { .card-grid { grid-template-columns: 1fr 1fr; } }
.card-grid div { display: grid; grid-template-columns: 48px 1fr; gap: 8px; }
.card-grid dt { font-size: 12px; font-weight: 700; color: var(--accent); margin: 0; }
.card-grid dd { margin: 0; font-size: 13px; }
.card-benefits { margin: 12px 0 0; font-size: 12.5px; color: var(--ink-soft); line-height: 1.8; }
.card-benefits span { display: inline-block; font-weight: 700; color: var(--accent-2);
  margin-right: 6px; background: var(--accent-2-soft); border-radius: 6px; padding: 1px 8px; }
.card-price { display: flex; flex-wrap: wrap; align-items: baseline; gap: 10px; margin-top: 14px;
  padding-top: 12px; border-top: 1px dashed var(--line); }
.price-main { font-family: var(--font-head); font-weight: 700; font-size: 22px; color: var(--ink); }
.price-disc { font-size: 12.5px; font-weight: 700; color: var(--ok); }
.price-net { margin-left: auto; font-family: var(--font-head); font-weight: 700; color: var(--accent-2); }

/* ---- 集計（横棒グラフ） ---- */
.summary { margin-top: 40px; background: var(--surface); border: 1px solid var(--line);
  border-radius: var(--radius); padding: 24px; box-shadow: var(--shadow); }
.summary-head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 8px; }
.summary-head h2 { font-family: var(--font-head); margin: 0; font-size: 22px; color: var(--accent); }
.summary-total { font-size: 14px; color: var(--ink-soft); }
.summary-total strong { font-family: var(--font-head); font-size: 24px; color: var(--accent-2); }
.summary-note { margin: 6px 0 16px; font-size: 12px; color: var(--ink-soft); }
.bars { display: grid; gap: 11px; margin-top: 10px; }
.bar-row { display: grid; grid-template-columns: 78px 1fr auto; gap: 10px; align-items: center; }
.bar-label { font-size: 13px; font-weight: 700; }
.bar-track { background: var(--bg-soft); border-radius: 999px; height: 16px; overflow: hidden; border: 1px solid var(--line); }
.bar-fill { height: 100%; width: 0; border-radius: 999px;
  background: linear-gradient(90deg, var(--grad-from), var(--grad-to)); transition: width .9s cubic-bezier(.2,.7,.2,1); }
.bar-row.is-minus .bar-fill { background: linear-gradient(90deg, var(--ok), #7bbf99); }
.bar-val { font-weight: 700; font-size: 13px; white-space: nowrap; }
.is-visible .bar-fill { width: var(--w); }

/* 空セクション */
.empty { color: var(--ink-soft); font-size: 13px; padding: 12px; background: var(--bg-soft); border-radius: 10px; }

/* フッター */
.foot { margin-top: 48px; padding-top: 18px; border-top: 2px solid var(--gold); text-align: center; font-size: 12px; color: var(--ink-soft); }

/* ---- 出現演出（IntersectionObserver で .is-visible 付与） ---- */
.reveal { opacity: 0; transform: translateY(14px); transition: opacity .6s ease, transform .6s ease; }
.reveal.is-visible { opacity: 1; transform: none; }
@media (prefers-reduced-motion: reduce) { .reveal { opacity: 1 !important; transform: none !important; transition: none; } }

/* ===================================================================== */
/* 印刷 / PDF 忠実化（最重要）                                            */
/* ===================================================================== */
@media print {
  *, *::before, *::after {
    -webkit-print-color-adjust: exact !important;
    print-color-adjust: exact !important;
  }
  @page { size: A4; margin: 14mm 12mm; }
  html { scroll-behavior: auto; }
  body { background: #fff; font-size: 11pt; }
  .wrap { max-width: none; padding: 0; }
  .no-print { display: none !important; }
  .reveal { opacity: 1 !important; transform: none !important; transition: none !important; }
  .bar-fill { width: var(--w) !important; transition: none !important; }
  /* 分断防止 */
  .item, .card, .stat, .toc, .summary, .routemap, .day-hd, .route { break-inside: avoid; page-break-inside: avoid; }
  .day { break-inside: auto; }
  h1, h2, .day-hd, .hero-title { break-after: avoid; }
  .hero, .toc, .summary, .routemap, .stat, .card { box-shadow: none; }
  .hero { padding: 6mm 0; }
  .day-no { font-size: 40px; }
  /* グラデーション文字は単色フォールバック（確実に視認） */
  .hero-title { -webkit-text-fill-color: var(--accent) !important; color: var(--accent) !important; background: none !important; }
  /* ルート図は線画として綺麗に出る。発着以降の章で改ページ */
  .routemap { page-break-after: always; }
  a { color: var(--ink); }
  /* 写真は印刷時はフィルタ解除で鮮明に。図版は分断しない */
  .item-photo, .card-photo, .hero-photo { break-inside: avoid; }
  .item-photo img, .card-photo img { filter: none !important; mix-blend-mode: normal !important; opacity: 1 !important; }
}
</style>
</head>
<body>
<div class="progress no-print" id="progress" role="presentation"></div>
<nav class="nav no-print">
  <span class="nav-title">{{ doc.meta.title }}</span>
  <span class="nav-spacer"></span>
  <button class="btn" id="printBtn" type="button">{{ m.icon('print') }}PDF・印刷</button>
</nav>

<main class="wrap">
  {{ m.hero(doc) }}
  {{ m.route_map(doc) }}
  {{ m.toc(doc) }}

  {% for sec in doc.sections %}{{ m.section(sec, loop.index) }}{% endfor %}

  {% if doc.summary %}{{ m.cost_summary(doc.summary) }}{% endif %}

  <footer class="foot">
    <p>{{ doc.meta.title }}{% if doc.meta.created %} ／ 作成 {{ doc.meta.created }}{% endif %}</p>
    <p>立寄り <span class="num">{{ doc.item_count }}</span> 件・宿泊 <span class="num">{{ doc.lodging_count }}</span> 泊</p>
  </footer>
</main>

<script>
(function () {
  "use strict";
  var reduceMotion = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  /* ---- localStorage ガード（無効環境でもメモリ動作） ---- */
  var STORE_KEY = "itinerary-done:{{ store_key }}";
  var mem = {};
  var ls = (function () {
    try {
      var t = "__t__"; window.localStorage.setItem(t, t); window.localStorage.removeItem(t);
      return window.localStorage;
    } catch (e) { return null; }
  })();
  function loadDone() {
    if (!ls) return mem;
    try { return JSON.parse(ls.getItem(STORE_KEY) || "{}") || {}; }
    catch (e) { return {}; }
  }
  function saveDone(state) {
    if (!ls) { mem = state; return; }
    try { ls.setItem(STORE_KEY, JSON.stringify(state)); }
    catch (e) { mem = state; }
  }

  /* ---- 訪問済みチェック（タップで切替＋保存） ---- */
  var done = loadDone();
  var items = document.querySelectorAll(".item[data-id]");
  items.forEach(function (el) {
    var id = el.getAttribute("data-id");
    var btn = el.querySelector(".item-check");
    if (done[id]) { el.classList.add("is-done"); if (btn) btn.setAttribute("aria-pressed", "true"); }
    if (btn) btn.addEventListener("click", function () {
      var now = !el.classList.contains("is-done");
      el.classList.toggle("is-done", now);
      btn.setAttribute("aria-pressed", now ? "true" : "false");
      done[id] = now;
      if (!now) { delete done[id]; }
      saveDone(done);
    });
  });

  /* ---- 進捗バー ---- */
  var progress = document.getElementById("progress");
  function onScroll() {
    var h = document.documentElement;
    var max = (h.scrollHeight - h.clientHeight);
    var p = max > 0 ? (h.scrollTop || document.body.scrollTop) / max : 0;
    if (progress) progress.style.width = (p * 100).toFixed(1) + "%";
  }
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  /* ---- 出現演出（IntersectionObserver / 非対応・低モーションは即表示） ---- */
  var reveals = document.querySelectorAll(".reveal");
  if (reduceMotion || !("IntersectionObserver" in window)) {
    reveals.forEach(function (el) { el.classList.add("is-visible"); });
  } else {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (en) {
        if (en.isIntersecting) { en.target.classList.add("is-visible"); io.unobserve(en.target); }
      });
    }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });
    reveals.forEach(function (el) { io.observe(el); });
  }

  /* ---- 印刷ボタン ---- */
  var printBtn = document.getElementById("printBtn");
  if (printBtn) printBtn.addEventListener("click", function () { window.print(); });
})();
</script>
</body>
</html>
